[Unit]
Description=CertShield ADCS Defensive Visibility App
After=network-online.target
Wants=network-online.target

[Service]
User=certshield
Group=certshield
WorkingDirectory=/opt/certshield
EnvironmentFile=/opt/certshield/.env
ExecStart=/opt/certshield/.venv/bin/uvicorn app.main:app --host ${BIND_HOST} --port ${BIND_PORT}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
