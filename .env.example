# Core application settings
APP_NAME=CertShield
APP_ENV=development
APP_VERSION=0.3.0
BUILD_NAME=Phase 1.1 UI and Scoring Stabilization
BUILD_LABEL=Phase 1.1
SECRET_KEY=replace-with-strong-random-secret

# Web bind settings
BIND_HOST=0.0.0.0
BIND_PORT=8000
SESSION_COOKIE_NAME=certshield_session
SESSION_HTTPS_ONLY=false

# Database
DB_URL=sqlite:///./certshield.db

# Bootstrap admin credentials (created at first startup if missing)
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeNow!

# Collector auth token (must match Windows collector)
COLLECTOR_API_TOKEN=collector-dev-token-change-me
